{
  "version": 2,
  "builds": [
    {
      "src": "ecommerce-backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "ecommerce-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "ecommerce-backend/server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "ecommerce-frontend/static/$1"
    },
    {
      "src": "/favicon.png",
      "dest": "ecommerce-frontend/favicon.png"
    },
    {
      "src": "/manifest.json",
      "dest": "ecommerce-frontend/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "ecommerce-frontend/index.html"
    }
  ]
}
